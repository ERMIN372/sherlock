# ─── Face Search provider ──────────────────────────────────────────────────
# Which provider to use: "facecheck" | "demo"
# Leave empty to auto-select: facecheck when FACECHECK_API_TOKEN is set,
# otherwise the built-in demo adapter.
FACE_SEARCH_PROVIDER=

# FaceCheck.ID API token (https://facecheck.id/Face-Search-API).
# Required for live results. Without it the app runs in demo mode.
FACECHECK_API_TOKEN=

# Optional: override the FaceCheck base URL (defaults to https://facecheck.id)
FACECHECK_API_URL=

# Optional: when "true", FaceCheck runs in testing mode (no credits spent,
# canned results). Useful while integrating.
FACECHECK_TESTING_MODE=

# ─── Rate limiting (per client IP) ─────────────────────────────────────────
# Max search requests per window, and window length in milliseconds.
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000
