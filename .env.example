# ─── Face Search provider ──────────────────────────────────────────────────
# Which provider to use: "facecheck" | "demo"
# Leave empty to auto-select: facecheck when FACECHECK_API_TOKEN is set,
# otherwise the built-in demo adapter.
FACE_SEARCH_PROVIDER=

# FaceCheck.ID API token (https://facecheck.id/Face-Search-API).
# Required for live results. Without it the app runs in demo mode.
FACECHECK_API_TOKEN=

# Optional: override the FaceCheck base URL (defaults to https://facecheck.id)
FACECHECK_API_URL=

# Optional: when "true", FaceCheck runs in TESTING MODE — it scans only a
# small subset (~100k faces), spends NO credits, but results are inaccurate and
# the queue can be slow. Great for wiring up the integration before paying.
# Set to "false" (or remove) for real, full-web results in production.
FACECHECK_TESTING_MODE=true

# ─── Rate limiting (per client IP) ─────────────────────────────────────────
# Max search requests per window, and window length in milliseconds.
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# ─── Payments (Stripe) ─────────────────────────────────────────────────────
# Stripe secret key. When set, the "Buy credits" flow uses real Stripe
# Checkout. When empty, the app falls back to the instant demo grant.
STRIPE_SECRET_KEY=

# Optional: webhook signing secret (Stripe Dashboard -> Developers -> Webhooks)
# for the /api/payment/webhook endpoint. Not required for the verify-on-return
# flow, but recommended for auditable production payments.
STRIPE_WEBHOOK_SECRET=

# Optional: absolute site URL used as a fallback for Stripe return URLs when the
# request origin is unavailable (e.g. https://your-domain.com).
NEXT_PUBLIC_SITE_URL=
