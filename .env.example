# ─── Face Search provider ──────────────────────────────────────────────────
# Which provider to use: "facecheck" | "demo"
# Leave empty to auto-select: facecheck when FACECHECK_API_TOKEN is set,
# otherwise the built-in demo adapter.
FACE_SEARCH_PROVIDER=

# FaceCheck.ID API token (https://facecheck.id/Face-Search-API).
# Required for live results. Without it the app runs in demo mode.
FACECHECK_API_TOKEN=

# Optional: override the FaceCheck base URL (defaults to https://facecheck.id)
FACECHECK_API_URL=

# Optional: when "true", FaceCheck runs in TESTING MODE — it scans only a
# small subset (~100k faces), spends NO credits, but results are inaccurate and
# the queue can be slow. Great for wiring up the integration before paying.
# Set to "false" (or remove) for real, full-web results in production.
FACECHECK_TESTING_MODE=true

# ─── Rate limiting (per client IP) ─────────────────────────────────────────
# Max search requests per window, and window length in milliseconds.
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# ─── Payments ──────────────────────────────────────────────────────────────
# Which payment provider to use: "yookassa" | "stripe".
# Leave empty to auto-detect by which keys are set (YooKassa takes priority).
# If no keys are set, the app uses an instant demo grant (no real payment).
PAYMENT_PROVIDER=

# YooKassa (for Russia) — Dashboard -> Settings -> API keys.
# Prices are charged in RUB.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Stripe (non-RU) — prices are charged in USD.
STRIPE_SECRET_KEY=
# Optional: Stripe webhook signing secret for /api/payment/webhook.
STRIPE_WEBHOOK_SECRET=

# Optional: absolute site URL used as a fallback for payment return URLs when
# the request origin is unavailable (e.g. https://your-domain.com).
NEXT_PUBLIC_SITE_URL=

# ─── Server-side credit wallet ─────────────────────────────────────────────
# Upstash Redis (Vercel -> Storage -> Marketplace -> Upstash) — stores each
# anonymous wallet's balance on the server so credits can't be edited
# client-side. REQUIRED in production (without it the app uses a non-persistent
# in-memory store = dev/demo only). The Upstash integration injects these
# automatically; both naming styles are supported:
#   KV_REST_API_URL / KV_REST_API_TOKEN   (Vercel KV style)
#   UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN   (Upstash style)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Secret used to sign the anonymous wallet cookie (any long random string).
# Strongly recommended in production to prevent wallet-id forgery.
WALLET_SECRET=
